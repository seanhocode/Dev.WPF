<Window x:Class="Example.Template.Example2Window"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Example.Template"
        mc:Ignorable="d"
        Title="Example2Window" Height="450" Width="800">
    <Grid>
        <Grid.Resources>
            <!--將 Template 設定放入 Style 中，這樣就可以統一設定所有 Button 的 Template-->
            <Style TargetType="Button">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Grid>
                                <Rectangle RadiusX="15" RadiusY="15" 
                                           Fill="{TemplateBinding Background}"
                                           Width="{TemplateBinding Width}"
                                           Height="{TemplateBinding Height}"/>
                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="LightBlue" />
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background">
                                        <Setter.Value>LightGreen</Setter.Value>
                                    </Setter>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </Grid.Resources>
        <Button Content="&lt;" FontSize="36" HorizontalAlignment="Left" VerticalAlignment="Center" />
        <Button Content="&gt;" FontSize="36" HorizontalAlignment="Right" VerticalAlignment="Center" />
        <Button Content="O" FontSize="36" HorizontalAlignment="Center" VerticalAlignment="Center" />
        <Button Content="^" FontSize="36" HorizontalAlignment="Center" VerticalAlignment="Top" />
        <Button Content="v" FontSize="36" HorizontalAlignment="Center" VerticalAlignment="Bottom" />
    </Grid>
</Window>
