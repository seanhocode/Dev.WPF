<Window x:Class="Example.WPF.Template.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Example.WPF.Template"
        mc:Ignorable="d"
        Title="TemplateExample" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Button Content="基本範例" FontSize="36" Click="OpenExample1Window" Grid.Row="0" />
        <Button Content="嵌入Style範例" FontSize="36" Click="OpenExample2Window" Grid.Row="1" />
    </Grid>
</Window>
