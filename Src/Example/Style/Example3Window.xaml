<Window x:Class="Example.Style.Example3Window"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Example.Style"
        mc:Ignorable="d"
        Title="Example3Window" Height="450" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.Resources>
            <Style TargetType="Button">
                <!--
                    1. Style 可以透過 Trigger 來設定控件的屬性值，當觸發條件成立時，會套用 Trigger 中的 Setter 設定
                    2. 當條件不再滿足時，系統會自動將屬性還原到觸發前的狀態
                -->
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Foreground" Value="Red" />
                        <!--Style.Triggers.Background 的觸發器優先級低於 Template，故無法使用 Style.Triggers.Background 改變預設背景-->
                        <Setter Property="Background" Value="Green" />
                    </Trigger>
                </Style.Triggers>
                <Setter Property="FontSize" Value="36" />
            </Style>
        </Grid.Resources>
        <Button Content="Button1" Grid.Column="0" />
        <Button Content="Button2" Grid.Column="1" />
    </Grid>
</Window>
