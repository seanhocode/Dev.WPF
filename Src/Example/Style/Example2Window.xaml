<Window x:Class="Example.Style.Example2Window"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Example.Style"
        mc:Ignorable="d"
        Title="Example2Window" Height="450" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.Resources>
            <!--
                1. Style 可以透過 BasedOn 屬性來繼承其他 Style 的設定
                2. 可定義多種 Style 並設定 x:Key 屬性來命名，並透過 StaticResource 或 DynamicResource 來指定引用 (必須要指定控件的 Style 屬性才能套用有設定 x:Key 的 Style)
                3. 也可以不設定 x:Key 屬性，這樣就會成為預設的 Style，所有沒有指定 Style 的控件都會使用這個預設的 Style
            -->
            <Style x:Key="ButtonStyleBase" TargetType="Button">
                <Setter Property="FontSize" Value="36" />
                <Setter Property="Margin" Value="50" />
                <Setter Property="Padding" Value="10,10" />
            </Style>
            
            <Style x:Key="ButtonStyleBlue" TargetType="Button" BasedOn="{StaticResource ButtonStyleBase}">
                <Setter Property="Background" Value="LightBlue" />
                <Setter Property="Foreground" Value="DarkBlue" />
            </Style>
            
            <Style x:Key="ButtonStyleRed" TargetType="Button" BasedOn="{StaticResource ButtonStyleBase}">
                <Setter Property="Background" Value="LightCoral" />
                <Setter Property="Foreground" Value="DarkRed" />
            </Style>
            
            <Style TargetType="Button" BasedOn="{StaticResource ButtonStyleBase}">
                <Setter Property="Background" Value="LightGreen" />
                <Setter Property="Foreground" Value="DarkGreen" />
            </Style>
        </Grid.Resources>
        <Button Content="ButtonBlue" Grid.Column="0" Grid.Row="0" Style="{StaticResource ButtonStyleBlue}" />
        <Button Content="ButtonRed" Grid.Column="1" Grid.Row="0" Style="{StaticResource ButtonStyleRed}" />
        <Button Content="ButtonGreen" Grid.Column="0" Grid.Row="1" Grid.ColumnSpan="2" />
    </Grid>
</Window>
