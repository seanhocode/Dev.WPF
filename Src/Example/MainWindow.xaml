<Window x:Class="Example.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Example"
        mc:Ignorable="d"
        Title="Dev.WPF.Example" Height="450" Width="800">
    <StackPanel>
        <Label Content="Hello, World!" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="36" />
        <Button Content="LayoutExample" FontSize="36" Click="OpenLayoutExampleWindow" />
        <Button Content="StyleExample" FontSize="36" Click="OpenStyleExampleWindow" />
        <Button Content="TemplateExample" FontSize="36" Click="OpenTemplateExampleWindow" />
        <Button Content="XAMLExample" FontSize="36" Click="OpenXAMLExampleWindow" />
        <Button Content="ResorceExample" FontSize="36" Click="OpenResourceExampleWindow" />
        <Button Content="AttachedPropertyExample" FontSize="36" Click="OpenAttachedPropertyExampleWindow" />
        <Button Content="MarkupExtensionsExample" FontSize="36" Click="OpenMarkupExtensionsExampleWindow" />
    </StackPanel>
</Window>
