<Window x:Class="Example.Layout.Grid.Example3Window"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Example.Layout.Grid"
        mc:Ignorable="d"
        Title="Example3Window" Height="450" Width="800">
    <Grid>
        <!--未定義 ColumnDefinition 與 RowDefinition，則定義在 Grid 中的控件會依照宣告順序「由下往上」堆疊-->
        <Button Content="Button1" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="180" />
        <Button Content="Button2" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="168" />
        <Button Content="Button3" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="156" />
        <Button Content="Button4" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="144" />
        <Button Content="Button5" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="132" />
        <Button Content="Button6" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="120" />
        <Button Content="Button7" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="108" />
        <Button Content="Button8" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="96" />
        <Button Content="Button9" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="84" />
    </Grid>
</Window>
