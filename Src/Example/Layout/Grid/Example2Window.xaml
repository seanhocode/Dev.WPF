<Window x:Class="Example.Layout.Grid.Example2Window"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Example.Layout.Grid"
        mc:Ignorable="d"
        Title="Example2Window" Height="600" Width="1200">
    <Grid>
        <Grid.RowDefinitions>
            <!--想要讓大小按比例分配，也可以用 [Number]* 來表示此格需要占用的比例-->
            <RowDefinition Height="4*" />
            <RowDefinition Height="2*" />
            <RowDefinition Height="1*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <!--如果有多格都使用 * 來定義大小，則會均分剩下的空間-->
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="3*" />
        </Grid.ColumnDefinitions>
        <Button Grid.Row="0" Grid.Column="0" Content="Row0(4*)Col0(2*)" />
        <!--可以透過設定 Grid.RowSpan 或是 Grid.ColumnSpan 讓 Grid 內部的控件佔據多個網格-->
        <Button Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" Content="Row0(4*)[Col1(2*) + Col2(3*)]" />
        <Button Grid.Row="1" Grid.Column="0" Grid.RowSpan="2" Content="[Row1(2*) + Row2(1*)]Col0(1*)" />
        <Button Grid.Row="1" Grid.Column="1" Grid.RowSpan="2" Grid.ColumnSpan="2" Content="[Row1(2*) + Row2(1*)][Col1(2*) + Col2(3*)]" />
    </Grid>
</Window>
