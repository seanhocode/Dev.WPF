<Window x:Class="Example.WPF.Layout.Grid.Example1Window"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Example.WPF.Layout.Grid"
        mc:Ignorable="d"
        Title="Example1Window" Height="450" Width="800">
    <!--
        Grid:
            一個容器控件，可以用來排列子控件，
            可以定義多個 ColumnDefinition 與 RowDefinition，形成一個網格，
            當 Grid 大小改變時，Grid 的網格大小會符合定義隨之改變，
            寬度跟高度除了可以用數字表示之外，也可以用 auto 與 * 表示:
                1. auto => 代表網格大小會自動符合內部元素的大小
                2.  *   => 表示扣除其他格佔的空間，剩下的空間就是本格的大小
            不應過度使用 auto 與 *，因為 Grid 需要不斷計算每個網格的大小，過度使用會影響效能
    -->
    <Grid>
        <!--Column Definitions: 定義列-->
        <Grid.ColumnDefinitions>
            <!--ColumnDefinition: 定義單一列的寬度-->
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <!--Row Definitions: 定義行-->
        <Grid.RowDefinitions>
            <!--RowDefinition: 定義單一行的高度-->
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <!--控件透過設定 Grid.Row 與 Grid.Column 屬性來指定所在的行與列-->
        <Button Grid.Row="0" Grid.Column="0" Content="Row0(*)Col0(*)" />
        <Button Grid.Row="0" Grid.Column="1" Content="Row0(*)Col1(Auto)" />
        <Button Grid.Row="1" Grid.Column="0" Content="Row1(Auto)Col0(*)" />
        <Button Grid.Row="1" Grid.Column="1" Content="Row1(Auto)Col1(Auto)" />
    </Grid>
</Window>
