<Window x:Class="Example.Layout.Grid.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Example.Layout.Grid"
        mc:Ignorable="d"
        Title="GridExample" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Button Grid.Row="0" Content="基本範例" Click="OpenExample1Window" FontSize="36" />
        <Button Grid.Row="1" Content="跨欄跨列範例" Click="OpenExample2Window" FontSize="36" />
        <Button Grid.Row="2" Content="未定義Definition範例" Click="OpenExample3Window" FontSize="36" />
    </Grid>
</Window>
