<Window x:Class="Example.Layout.DockPanel.Example1Window"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Example.Layout.DockPanel"
        mc:Ignorable="d"
        Title="Example1Window" Height="450" Width="800">
    <!--
        DockPanel:
            可以讓子元素依照指定方向 (Dock) 排列的容器，
            如果同時設定了 DockPanel.Dock 屬性，則會依照加入的順序排列，
            如果沒有設定 DockPanel.Dock 屬性，則會使用預設值 Left
    -->
    <DockPanel>
        <!--Dock 預設設定為 Left，代表子元素會靠左排列-->
        <Button Content="DefaultLeft" />
        <!--Dock 設定為 Right，代表子元素會靠右排列-->
        <Button Content="Right" DockPanel.Dock="Right" />
        <!--Dock 設定為 Top，代表子元素會靠上排列-->
        <Button Content="Top" DockPanel.Dock="Top" />
        <!--Dock 設定為 Bottom，代表子元素會靠下排列-->
        <Button Content="Bottom" DockPanel.Dock="Bottom" />
        <Button Content="Auto" />
    </DockPanel>
</Window>
