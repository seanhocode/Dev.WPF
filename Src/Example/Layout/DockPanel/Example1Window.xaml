<Window x:Class="Example.Layout.DockPanel.Example1Window"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Example.Layout.DockPanel"
        mc:Ignorable="d"
        Title="Example1Window" Height="450" Width="800">
    <!--
        1. DockPanel 是一個可以將子元素依照指定方向(Dock)排列的容器
        2. DockPanel 的 Dock 預設為 Left，代表子元素會靠左排列
        3. DockPanel 的 Dock 設定為 Right，代表子元素會靠右排列
        4. DockPanel 的 Dock 設定為 Top，代表子元素會靠上排列
        5. DockPanel 的 Dock 設定為 Bottom，代表子元素會靠下排列
        6. DockPanel 的子元素會依照加入的順序排列
    -->
    <DockPanel>
        <Button Content="Left" DockPanel.Dock="Left" />
        <Button Content="Right" DockPanel.Dock="Right" />
        <Button Content="Top" DockPanel.Dock="Top" />
        <Button Content="Bottom" DockPanel.Dock="Bottom" />
        <Button Content="Auto" />
    </DockPanel>
</Window>
