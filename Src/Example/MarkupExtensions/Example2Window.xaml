<Window x:Class="Example.WPF.MarkupExtensions.Example2Window"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Example.WPF.MarkupExtensions"
        xmlns:extension="clr-namespace:Example.WPF.MarkupExtensions.Extension"
        mc:Ignorable="d"
        Title="Example2Window" Height="450" Width="800">
    <Grid>
        <Grid.Resources>
            <Style x:Key="ButtonStyle" TargetType="Button">
                <Setter Property="FontSize" Value="72" />
                <Setter Property="HorizontalAlignment" Value="Center" />
                <Setter Property="VerticalAlignment" Value="Center" />
            </Style>
            <Style x:Key="ButtonColorStyle" TargetType="Button">
                <Setter Property="Foreground" Value="Green" />
                <Setter Property="Background" Value="DarkGray" />
            </Style>
        </Grid.Resources>
        <Button Content="Hello World"
            Style="{extension:MergeStyle BasedOn={StaticResource ButtonStyle}, MergeWith={StaticResource ButtonColorStyle}}" />
    </Grid>
</Window>
