<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style x:Key="SmallLabelStyleBase" TargetType="Label">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Background" Value="LightGray" />
    </Style>

    <Style x:Key="SmallLabelStyleBlue" TargetType="Label" BasedOn="{StaticResource SmallLabelStyleBase}">
        <Setter Property="Foreground" Value="Blue" />
    </Style>

    <Style x:Key="SmallLabelStyleRed" TargetType="Label" BasedOn="{StaticResource SmallLabelStyleBase}">
        <Setter Property="Foreground" Value="Red" />
    </Style>

</ResourceDictionary>