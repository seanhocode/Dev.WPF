<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style x:Key="BigLabelStyleBase" TargetType="Label">
        <Setter Property="FontSize" Value="60" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Background" Value="LightGray" />
    </Style>

    <Style x:Key="BigLabelStyleBlue" TargetType="Label" BasedOn="{StaticResource BigLabelStyleBase}">
        <Setter Property="Foreground" Value="Blue" />
    </Style>

    <Style x:Key="BigLabelStyleRed" TargetType="Label" BasedOn="{StaticResource BigLabelStyleBase}">
        <Setter Property="Foreground" Value="Red" />
    </Style>
</ResourceDictionary>