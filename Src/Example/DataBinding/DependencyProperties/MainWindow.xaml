<Window x:Class="Example.WPF.DataBinding.DependencyProperties.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Example.WPF.DataBinding.DependencyProperties"
        mc:Ignorable="d"
        Title="Dependency Property Example" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Button Grid.Row="0" Content="錯誤範例" FontSize="36" Click="OpenErrorExample1Window" />
        <Button Grid.Row="1" Content="基本範例" FontSize="36" Click="OpenExample1Window" />
    </Grid>
</Window>
