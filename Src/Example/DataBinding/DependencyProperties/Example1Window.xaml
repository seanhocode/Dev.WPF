<Window x:Class="Example.WPF.DataBinding.DependencyProperties.Example1Window"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Example.WPF.DataBinding.DependencyProperties"
        xmlns:userControls="clr-namespace:Example.WPF.DataBinding.DependencyProperties.UserControls"
        xmlns:model="clr-namespace:Example.WPF.Core.Model.DataBinding.DependencyProperties;assembly=Example.WPF.Core"
        mc:Ignorable="d"
        Title="{x:Static model:Example1Definition.Title}" Height="450" Width="800">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Label Content="{x:Static model:Example1Definition.Description}" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center" />
        <!--因 FirstUserControl 已註冊相依屬性 (Dependency Property)，因此可以使用 Binding 將資料來源綁定至該相依屬性-->
        <userControls:FirstUserControl Grid.Row="1" FirstUserControlValue="{Binding FirstDataContextValue}" />
    </Grid>
</Window>
