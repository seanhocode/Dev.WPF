<Window x:Class="Example.WPF.DataBinding.DependencyProperties.Example1Window"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Example.WPF.DataBinding.DependencyProperties"
        xmlns:dataContext="clr-namespace:Example.WPF.Core.DataBinding.DataContexts;assembly=Example.WPF.Core"
        xmlns:userControls="clr-namespace:Example.WPF.DataBinding.DependencyProperties.UserControls"
        mc:Ignorable="d"
        Title="Example1Window" Height="450" Width="800">
    <Window.DataContext>
        <dataContext:FirstDataContext />
    </Window.DataContext>
    <Grid>
        <userControls:ErrorUserControl ErrorUserControlValue="{Binding FirstDataContextValue}" />
    </Grid>
</Window>
