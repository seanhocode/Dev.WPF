<Window x:Class="Example.WPF.DataBinding.DependencyProperties.ErrorExample1Window"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Example.WPF.DataBinding.DependencyProperties"
        xmlns:dataContext="clr-namespace:Example.WPF.Core.DataBinding.DataContexts;assembly=Example.WPF.Core"
        xmlns:userControls="clr-namespace:Example.WPF.DataBinding.DependencyProperties.UserControls"
        xmlns:model="clr-namespace:Example.WPF.Core.Model.DataBinding.DependencyProperties;assembly=Example.WPF.Core"
        mc:Ignorable="d"
        Title="{x:Static model:ErrorExample1Definition.Title}" Height="450" Width="800">
    <Window.DataContext>
        <dataContext:FirstDataContext />
    </Window.DataContext>
    <Grid>
        <Label Content="{x:Static model:ErrorExample1Definition.Description}" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center" />
        <userControls:ErrorUserControl ErrorUserControlValue="{Binding FirstDataContextValue}" />
    </Grid>
</Window>
