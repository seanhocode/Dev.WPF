<Window x:Class="Example.Resource.Example1Window"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Example.Resource"
        mc:Ignorable="d"
        Title="Example1Window" Height="450" Width="800">
    <Grid>
        <Grid.Resources>
            <!--
                ResourceDictionary (資源字典):
                    以鍵值對 (Key-Value Pair) 的形式，集中儲存、解析與管理應用程式中可重複使用的 UI 資源 (如畫筆、顏色、字型、樣式和控制項範本)，
                    字典內的每一個資源(除了隱式樣式)都必須帶有 x:Key 屬性，
                    定義在特定控制項內的資源字典只能給該控制項使用；定義在 Window 的能給整個視窗使用；定義在 App.xaml 的 Application 的則成為全域資源

                如何新增單獨資源字典檔:
                    1. 在 Solution Explorer 裡面右鍵點擊專案名稱，選擇 Add -> New Item
                    2. 選擇 Resource Dictionary (資源字典(R))
                    ex. Src/Example/Dictionary

                如何在 xaml 中引用資源字典檔:
                    1. 在 Resources 裡面定義 ResourceDictionary
                    2. 於 ResourceDictionary 裡透過 ResourceDictionary.MergedDictionaries 屬性來合併資源字典
                    3. 每個資源字典透過 ResourceDictionary 的 Source 來指定資源字典的 Uri
            -->
            <ResourceDictionary>
                <ResourceDictionary.MergedDictionaries>
                    <!--Pack URI 格式-->
                    <ResourceDictionary Source="pack://application:,,,/Dictionary/LabelStyle.xaml" />
                    <ResourceDictionary Source="pack://application:,,,/Dictionary/SmallLabelStyle.xaml" />
                </ResourceDictionary.MergedDictionaries>
            </ResourceDictionary>
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Label Grid.Row="0" Content="Hello World" Style="{StaticResource LabelStyleBlue}" />
        <Label Grid.Row="1" Content="Hello World" Style="{StaticResource SmallLabelStyleRed}" />
    </Grid>
</Window>
